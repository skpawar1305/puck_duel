# ── Signaling Server ──────────────────────────────────────────────────────────
# Matchbox signaling server URL (WebSocket). For India-only deployment, host this
# on your Mumbai Lightsail VPS for sub-10ms latency.
#   Local dev:  ws://localhost:8001
#   Production: wss://your-lightsail-domain.com
MATCHBOX_SIGNALING_URL=wss://puckduel.dano.win

# ── TURN Relay (coturn) ───────────────────────────────────────────────────────
# Required for users behind CGNAT (common on Jio/Airtel). Deploy coturn on your
# Mumbai Lightsail VPS using the setup script in scripts/setup-turn.sh.
# Example: turn:your-lightsail-ip:3478
# Leave empty if not using TURN.
TURN_SERVER_URL=
TURN_SERVER_USERNAME=
TURN_SERVER_PASSWORD=
