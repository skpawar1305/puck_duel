{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PuckDuel",
  "version": "1.7.6",
  "identifier": "com.dano.puckduel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "PuckDuel",
        "width": 800,
        "height": 600,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "versionCode": 176,
      "minSdkVersion": 28
    }
  },
  "plugins": {
    "log": {
      "enabled": true
    }
  }
}